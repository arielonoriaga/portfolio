# Environment variables for the portfolio
# Copy to .env.local and update as needed

# Application
NODE_ENV=production
APP_NAME=Ariel Onoriaga Portfolio
APP_URL=https://arielonoriaga.huggian.com

# Docker (for docker-compose)
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_NAME=arielonoriaga/portfolio
DOCKER_IMAGE_TAG=latest

# Deployment (configure in GitHub secrets, not here)
# DEPLOY_HOST=your-server.com
# DEPLOY_USER=deploy
# DEPLOY_KEY=<ssh-private-key>
